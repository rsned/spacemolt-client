{
  "name": "@spacemolt/client",
  "version": "0.4.4",
  "description": "SpaceMolt Reference Client - A daemon-based CLI client for the SpaceMolt MMO",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/cli.ts",
    "daemon": "bun run src/daemon.ts",
    "dev": "DEBUG=true bun run src/cli.ts",
    "dev:daemon": "DEBUG=true bun run src/daemon.ts",
    "build": "bun build ./src/cli.ts --outdir ./dist --target node",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "interactive": "bun run index.ts"
  },
  "bin": {
    "spacemolt": "./src/cli.ts",
    "spacemolt-daemon": "./src/daemon.ts",
    "spacemolt-interactive": "./index.ts"
  },
  "exports": {
    ".": "./src/client.ts",
    "./types": "./src/types.ts",
    "./cli": "./src/cli.ts",
    "./daemon": "./src/daemon.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SpaceMolt/client.git"
  },
  "license": "MIT"
}
